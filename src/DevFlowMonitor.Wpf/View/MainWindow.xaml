<Window x:Class="DevFlowMonitor.Wpf.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:DevFlowMonitor.Wpf.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        d:DataContext="{d:DesignInstance Type=viewModel:MainViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="#E8E0CC">

            <TextBlock FontSize="18" Margin="20" Foreground="#2D2E27">DevFlow Monitor</TextBlock>

            <Separator Foreground="#C8BFA8"/>

            <ToggleButton Style="{StaticResource PanelItem}"
                          IsChecked="{Binding IsDashboardActive, Mode=OneWay}"
                          Command="{Binding NavigateToDashboardCommand}">
                <WrapPanel>
                    <Image Source="{StaticResource DashboardIcon}"/>
                    <TextBlock>Dashboard</TextBlock>
                </WrapPanel>
            </ToggleButton>

            <ToggleButton Style="{StaticResource PanelItem}"
                          IsChecked="{Binding IsPipelinesActive, Mode=OneWay}"
                          Command="{Binding NavigateToPipelinesCommand}">
                <WrapPanel>
                    <Image Source="{StaticResource BranchIcon}"/>
                    <TextBlock>Pipeline</TextBlock>
                </WrapPanel>
            </ToggleButton>

            <ToggleButton Style="{StaticResource PanelItem}"
                          IsChecked="{Binding IsSettingsActive, Mode=OneWay}"
                          Command="{Binding NavigateToSettingsCommand}">
                <WrapPanel>
                    <Image Source="{StaticResource SettingsIcon}"/>
                    <TextBlock>Settings</TextBlock>
                </WrapPanel>
            </ToggleButton>
        </StackPanel>

        <ContentControl Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>