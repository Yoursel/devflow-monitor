<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <SolidColorBrush x:Key="SuccessFg" Color="#1A4A2E"/>
    <SolidColorBrush x:Key="SuccessBg" Color="#BBF0CE"/>
    <SolidColorBrush x:Key="FailedFg"  Color="#5C1A1A"/>
    <SolidColorBrush x:Key="FailedBg"  Color="#FCC8C8"/>
    <SolidColorBrush x:Key="RunningFg" Color="#92400E"/>
    <SolidColorBrush x:Key="RunningBg" Color="#FEF3C7"/>

    <DataTemplate x:Key="StatusBadgeTemplate">
        <Border x:Name="Badge"
                CornerRadius="6"
                Padding="10,4"
                HorizontalAlignment="Left">
            <TextBlock x:Name="BadgeText"
                       FontSize="13"/>
        </Border>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="Success">
                <Setter TargetName="Badge"     Property="Background" Value="{StaticResource SuccessBg}"/>
                <Setter TargetName="BadgeText" Property="Foreground" Value="{StaticResource SuccessFg}"/>
                <Setter TargetName="BadgeText" Property="Text"       Value="success"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Failed">
                <Setter TargetName="Badge"     Property="Background" Value="{StaticResource FailedBg}"/>
                <Setter TargetName="BadgeText" Property="Foreground" Value="{StaticResource FailedFg}"/>
                <Setter TargetName="BadgeText" Property="Text"       Value="failed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Running">
                <Setter TargetName="Badge"     Property="Background" Value="{StaticResource RunningBg}"/>
                <Setter TargetName="BadgeText" Property="Foreground" Value="{StaticResource RunningFg}"/>
                <Setter TargetName="BadgeText" Property="Text"       Value="running"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="PipelineColumnHeaderStyle" TargetType="GridViewColumnHeader">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <TextBlock Text="{TemplateBinding Content}"
                               Background="#B8D4F0"
                               Foreground="#1A2E4A"
                               FontSize="13"
                               Padding="12,10"
                               VerticalAlignment="Center"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PipelineRowStyle" TargetType="ListViewItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="RowBorder"
                            Padding="0,6">
                        <GridViewRowPresenter VerticalAlignment="Center"
                                              Margin="12,0"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                <Condition Binding="{Binding Status}" Value="Success"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource SuccessBg}"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                <Condition Binding="{Binding Status}" Value="Failed"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource FailedBg}"/>
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                <Condition Binding="{Binding Status}" Value="Running"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowBorder" Property="Background" Value="{StaticResource RunningBg}"/>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PipelineListStyle" TargetType="ListView">
        <Setter Property="Background" Value="#FFFEF8"/>
        <Setter Property="BorderBrush" Value="#C8BFA8"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListView">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            UseLayoutRounding="True">
                        <Border CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#B8D4F0">
                                        <GridViewHeaderRowPresenter
                                            Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource TemplatedParent}}"
                                            ColumnHeaderContainerStyle="{Binding Path=View.ColumnHeaderContainerStyle, RelativeSource={RelativeSource TemplatedParent}}"
                                            ColumnHeaderTemplate="{Binding Path=View.ColumnHeaderTemplate, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    </Border>

                                    <ItemsPresenter/>
                                </DockPanel>
                            </ScrollViewer>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>