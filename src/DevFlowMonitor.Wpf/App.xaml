<Application x:Class="DevFlowMonitor.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Style/Resources.xaml"/>
                <ResourceDictionary Source="Style/Style.xaml"/>
                <ResourceDictionary Source="Style/ViewTemplates.xaml"/>
                <ResourceDictionary Source="Style/StatusCardTemplate.xaml"/>
                <ResourceDictionary Source="Style/PipelineTableTemplate.xaml"/>
                <ResourceDictionary Source="Style/PipelineItemStyle.xaml"/>    
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>